# NON-PRODUCTION ONLY. Never copy production values here or commit the real file.
# Keep the real .env.staging outside the repository history.
STAGING_SUPABASE_URL=https://YOUR-STAGING-PROJECT-REF.supabase.co
STAGING_SUPABASE_PUBLISHABLE_KEY=YOUR_STAGING_PUBLISHABLE_KEY
STAGING_SUPABASE_PROJECT_REF=YOUR-STAGING-PROJECT-REF

# Required safety allow-list. Use the same non-production ref as above.
STAGING_ALLOWED_PROJECT_REFS=YOUR-STAGING-PROJECT-REF
# Optional local block-list: put the operating project ref here, never in this example.
STAGING_BLOCKED_PROJECT_REFS=

# Public build label. This is intentionally not a secret.
APP_ENV=staging
APP_ENV_LABEL=비운영 검수환경

# Local administrator tools only; never expose this to Netlify browser code.
STAGING_SUPABASE_SERVICE_ROLE_KEY=YOUR_STAGING_SERVICE_ROLE_KEY
# Set at runtime, not in this file: STAGING_CONFIRM=STAGING
# Set at runtime, not in this file: STAGING_QA_PASSWORD=choose-a-temporary-password
